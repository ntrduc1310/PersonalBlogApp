@model PersonalBlogApp.Models.Blog

@{
    ViewData["Title"] = "Xóa bài viết";
}

<div class="container mt-2 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <a asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block small hover-primary-text">
                &larr; Hủy và quay lại
            </a>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid var(--color-border) !important;">
                <div class="card-header bg-danger bg-gradient text-white p-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2 text-white"></i>Xác nhận xóa bài viết</h4>
                    <small class="opacity-75">Hành động này là vĩnh viễn và không thể khôi phục.</small>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    <div class="alert alert-warning rounded-4 p-3 mb-4">
                        <h5 class="alert-heading fw-bold mb-2">Cảnh báo!</h5>
                        <p class="mb-0 small">
                            Bài viết này cùng với toàn bộ các **bình luận** liên kết sẽ bị xóa vĩnh viễn khỏi hệ thống.
                        </p>
                    </div>

                    <div class="bg-light p-3 rounded-4 mb-5">
                        <label class="form-label fw-semibold text-muted mb-1">Bài viết chuẩn bị xóa</label>
                        <div class="mt-2">
                            <h5 class="fw-bold text-dark mb-2">@Model.Title</h5>
                            <div class="d-flex gap-3 text-muted small mt-1">
                                <span><i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                <span>|</span>
                                <span><i class="bi bi-star-fill text-warning me-1"></i> Độ ưu tiên: Mức @Model.Priority</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-premium-danger rounded-pill px-4 py-2 flex-grow-1">
                                Xác nhận xóa vĩnh viễn
                            </button>
                            <a asp-action="Index" class="btn btn-premium-outline px-4 py-2 flex-grow-1 text-center">
                                Giữ lại bài viết
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>