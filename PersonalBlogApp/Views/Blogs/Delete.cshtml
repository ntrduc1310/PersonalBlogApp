@model PersonalBlogApp.Models.Blog

@{
    ViewData["Title"] = "Xóa bài viết";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger border-opacity-25 shadow-sm rounded-4">
                <div class="card-body p-5 text-center">

                    <!-- Icon cảnh báo -->
                    <div class="mb-4 text-danger opacity-75">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                        </svg>
                    </div>

                    <h3 class="fw-bold text-dark mb-3">Bạn chắc chắn muốn xóa bài viết này?</h3>
                    <p class="text-muted mb-4">
                        Bài viết <strong class="text-dark">"@Model.Title"</strong> sẽ bị xóa vĩnh viễn khỏi hệ thống và không thể khôi phục lại được.
                    </p>

                    <!-- Khung thông tin nhanh -->
                    <div class="bg-light rounded-3 p-3 mb-4 text-start">
                        <p class="mb-1 small"><span class="text-muted">Ngày tạo:</span> <span class="fw-medium text-dark">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></p>
                        <p class="mb-0 small"><span class="text-muted">Độ ưu tiên:</span> <span class="fw-medium text-dark">Mức @Model.Priority</span></p>
                    </div>

                    <!-- Form xác nhận -->
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 rounded-pill text-dark border">Hủy, giữ lại bài</a>
                            <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill">Vâng, xóa bài viết</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>