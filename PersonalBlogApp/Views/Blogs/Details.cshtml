@model PersonalBlogApp.Models.Blog
@using Ganss.Xss
@using Microsoft.AspNetCore.Identity
@using PersonalBlogApp.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Chi tiết bài viết";
    bool isAuthorized = User.IsInRole("Admin") || Model.UserId == UserManager.GetUserId(User);
}

<style>
    .article-header {
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
    }

    .article-title {
        font-size: 2.75rem;
        line-height: 1.25;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: var(--color-text-title);
    }

    .content-body {
        font-size: 1.15rem;
        line-height: 1.9;
        color: #334155;
    }

    .content-body p {
        margin-bottom: 1.5rem;
    }

    .content-body img {
        max-width: 100%;
        height: auto;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-md);
        margin: 2rem 0;
    }

    .avatar-circle {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--color-primary-start), var(--color-primary-end));
        color: #ffffff;
        font-weight: 700;
        box-shadow: 0 4px 10px rgba(99, 102, 241, 0.15);
    }
</style>

<div class="container mt-2 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <!-- Back to list link -->
            <a asp-action="Index" class="text-decoration-none text-muted mb-4 d-inline-flex align-items-center gap-1 small hover-primary-text">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>

            <article class="card border-0 bg-white shadow-sm p-4 p-md-5 mb-5" style="border-radius: 24px;">
                <div class="article-header">
                    <!-- Priority badge -->
                    <div class="mb-3">
                        @switch (Model.Priority)
                        {
                            case 5:
                                <span class="badge badge-custom badge-inactive">5 - Rất cao</span>
                                break;
                            case 4:
                                <span class="badge badge-custom badge-priority-high">4 - Cao</span>
                                break;
                            case 3:
                                <span class="badge badge-custom badge-user">3 - Trung bình</span>
                                break;
                            case 2:
                                <span class="badge badge-custom badge-active">2 - Thấp</span>
                                break;
                            default:
                                <span class="badge badge-custom bg-light text-dark">1 - Rất thấp</span>
                                break;
                        }
                    </div>

                    <!-- Article Title -->
                    <h1 class="article-title mb-4">@Model.Title</h1>

                    <!-- Meta information -->
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-circle">
                                @(Model.User?.Email?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@(Model.User?.Email ?? "Ẩn danh")</h6>
                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>

                        <!-- Management actions (if owner or Admin) -->
                        @if (isAuthorized)
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-premium-outline px-3 py-2">
                                    <i class="bi bi-pencil-square me-1"></i> Sửa bài
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-premium-outline-danger px-3 py-2">
                                    <i class="bi bi-trash-fill me-1"></i> Xóa
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <!-- Article Content -->
                <div class="content-body">
                    @{
                        var sanitizer = new HtmlSanitizer();
                        var sanitizedContent = sanitizer.Sanitize(Model.Content);
                    }
                    @Html.Raw(sanitizedContent)
                </div>
            </article>

            <!-- Comments Section -->
            <partial name="_CommentSection" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        /**
         * AJAX Commenting Pattern:
         * This script intercepts normal HTML form submissions for creating and deleting comments, 
         * and redirects them through async Fetch API requests. 
         * 
         * - Anti-Forgery (CSRF) Protection: The "__RequestVerificationToken" input automatically generated 
         *   by ASP.NET Core MVC is packaged within the FormData payload to successfully pass the server-side 
         *   [ValidateAntiForgeryToken] validation check.
         * 
         * - Dynamic DOM updates: We append new comments and delete old ones on the fly without refreshing the page, 
         *   updating the total count dynamically.
         */
        document.addEventListener("DOMContentLoaded", function () {
            const commentForm = document.getElementById("commentForm");
            const commentList = document.querySelector(".comment-list");
            const commentCountEl = document.querySelector(".comment-count");

            if (commentForm) {
                commentForm.addEventListener("submit", async function (e) {
                    e.preventDefault();

                    const formData = new FormData(commentForm);
                    
                    try {
                        const response = await fetch(commentForm.action, {
                            method: "POST",
                            body: formData,
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        });

                        if (response.ok) {
                            const data = await response.json();
                            if (data.success) {
                                // Remove placeholder if first comment
                                const noCommentMsg = commentList.querySelector(".fst-italic");
                                if (noCommentMsg) {
                                    noCommentMsg.remove();
                                }

                                // Get antiforgery token
                                const antiForgeryToken = commentForm.querySelector('input[name="__RequestVerificationToken"]').value;

                                // Build comment HTML
                                const avatarHtml = data.avatarUrl 
                                    ? `<img src="${data.avatarUrl}" class="rounded-circle shadow-sm border border-1 border-light" style="width: 44px; height: 44px; object-fit: cover;" alt="Avatar" />`
                                    : `<div class="bg-secondary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 44px; height: 44px; font-size: 1.1rem; background: #94a3b8 !important;">${data.avatarInitial}</div>`;

                                const newCommentHtml = `
                                     <div class="d-flex mb-4 comment-item" id="comment-${data.commentId}">
                                         <div class="flex-shrink-0">
                                             ${avatarHtml}
                                         </div>
                                         <div class="flex-grow-1 ms-3">
                                            <div class="comment-bubble position-relative">
                                                <div class="d-flex justify-content-between align-items-center mb-2 gap-3" style="padding-right: 2rem;">
                                                    <strong class="text-primary small">${data.userEmail}</strong>
                                                    <small class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-clock me-1"></i>${data.createdAt}</small>
                                                </div>
                                                <form action="/Comments/Delete/${data.commentId}" method="post" class="delete-comment-form position-absolute" style="top: 1rem; right: 1rem;">
                                                    <input type="hidden" name="__RequestVerificationToken" value="${antiForgeryToken}" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 p-0 rounded-circle"
                                                            title="Xóa bình luận"
                                                            onclick="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');"
                                                            style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; line-height: 1; transition: var(--transition-smooth); background-color: rgba(244, 63, 94, 0.05);">
                                                        <i class="bi bi-trash fs-6"></i>
                                                    </button>
                                                </form>
                                                <p class="mb-0 text-dark small" style="white-space: pre-line; line-height: 1.6;">${data.content}</p>
                                            </div>
                                         </div>
                                     </div>
                                 `;

                                // Insert at the top of the comment list
                                commentList.insertAdjacentHTML("afterbegin", newCommentHtml);
                                
                                // Reset form
                                commentForm.reset();

                                // Update count
                                if (commentCountEl) {
                                    const match = commentCountEl.textContent.match(/\d+/);
                                    if (match) {
                                        const count = parseInt(match[0]) + 1;
                                        commentCountEl.textContent = `Bình luận (${count})`;
                                    }
                                }
                            }
                        } else {
                            const errData = await response.json().catch(() => ({}));
                            alert(errData.message || "Không thể gửi bình luận.");
                        }
                    } catch (error) {
                        console.error("Error posting comment:", error);
                        alert("Đã xảy ra lỗi kết nối.");
                    }
                });
            }

            // AJAX Delete Comment (delegated handler)
            if (commentList) {
                commentList.addEventListener("submit", async function (e) {
                    if (e.target.classList.contains("delete-comment-form")) {
                        e.preventDefault();

                        const form = e.target;
                        const commentItem = form.closest(".comment-item");
                        const formData = new FormData(form);

                        try {
                            const response = await fetch(form.action, {
                                method: "POST",
                                body: formData,
                                headers: {
                                    "X-Requested-With": "XMLHttpRequest"
                                }
                            });

                            if (response.ok) {
                                const data = await response.json();
                                if (data.success) {
                                    // Remove comment item from DOM
                                    commentItem.remove();

                                    // Update count
                                    if (commentCountEl) {
                                        const match = commentCountEl.textContent.match(/\d+/);
                                        if (match) {
                                            const count = Math.max(0, parseInt(match[0]) - 1);
                                            commentCountEl.textContent = `Bình luận (${count})`;
                                            
                                            if (count === 0) {
                                                commentList.innerHTML = '<p class="text-muted fst-italic text-center py-4">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>';
                                            }
                                        }
                                    }
                                }
                            } else {
                                const errData = await response.json().catch(() => ({}));
                                alert(errData.message || "Bạn không có quyền xóa bình luận này.");
                            }
                        } catch (error) {
                            console.error("Error deleting comment:", error);
                            alert("Đã xảy ra lỗi khi xóa bình luận.");
                        }
                    }
                });
            }
        });
    </script>
}