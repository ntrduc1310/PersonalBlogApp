@model PersonalBlogApp.Models.Blog
@using Microsoft.AspNetCore.Identity
@using PersonalBlogApp.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Chi tiết bài viết";
    bool isAuthorized = User.IsInRole("Admin") || Model.UserId == UserManager.GetUserId(User);
}

<style>
    .article-meta {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 12px 20px;
        font-size: 0.9rem;
    }

    .content-body {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #333;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block">
                &larr; Quay lại danh sách
            </a>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">

                    <h1 class="fw-bold mb-4" style="color: #2c3e50;">@Model.Title</h1>

                    <div class="article-meta d-flex flex-wrap align-items-center justify-content-between mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <span class="text-muted fw-medium">
                                <i class="bi bi-person-circle me-1"></i> Tác giả: @(Model.User?.Email ?? "Ẩn danh")
                            </span>
                            <span class="text-muted">|</span>
                            <span class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>

                        <div class="mt-2 mt-md-0">
                            @switch (Model.Priority)
                            {
                                case 5:
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill">5 - Rất cao</span>
                                    ; break;
                                case 4:

                                    <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill">4 - Cao</span>
                                    ; break;
                                case 3:

                                    <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill">3 - Trung bình</span>
                                    ; break;
                                case 2:

                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-pill">2 - Thấp</span>
                                    ; break;
                                default:

                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">1 - Rất thấp</span>
                                    ; break;
                            }
                        </div>
                    </div>

                    <hr class="mb-4 text-muted opacity-25">

                    <!-- Nội dung bài viết -->
                    <div class="content-body">
                        @Html.Raw(Model.Content)
                    </div>

                </div>

                @if (isAuthorized)
                {
                    <div class="card-footer bg-white border-top-0 p-4 p-md-5 pt-0 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 rounded-pill">
                            Chỉnh sửa bài viết
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4 rounded-pill">
                            Xóa
                        </a>
                    </div>
                }
            </div>
            <partial name="_CommentSection" model="Model" />

        </div>
    </div>
</div>

@section Scripts {
    <script>
        /**
         * AJAX Commenting Pattern:
         * This script intercepts normal HTML form submissions for creating and deleting comments, 
         * and redirects them through async Fetch API requests. 
         * 
         * - Anti-Forgery (CSRF) Protection: The "__RequestVerificationToken" input automatically generated 
         *   by ASP.NET Core MVC is packaged within the FormData payload to successfully pass the server-side 
         *   [ValidateAntiForgeryToken] validation check.
         * 
         * - Dynamic DOM updates: We append new comments and delete old ones on the fly without refreshing the page, 
         *   updating the total count dynamically.
         */
        document.addEventListener("DOMContentLoaded", function () {
            const commentForm = document.getElementById("commentForm");
            const commentList = document.querySelector(".comment-list");
            const commentCountEl = document.querySelector(".comment-count");

            if (commentForm) {
                commentForm.addEventListener("submit", async function (e) {
                    e.preventDefault();

                    const formData = new FormData(commentForm);
                    
                    try {
                        const response = await fetch(commentForm.action, {
                            method: "POST",
                            body: formData,
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        });

                        if (response.ok) {
                            const data = await response.json();
                            if (data.success) {
                                // Remove placeholder if first comment
                                const noCommentMsg = commentList.querySelector(".fst-italic");
                                if (noCommentMsg) {
                                    noCommentMsg.remove();
                                }

                                // Get antiforgery token
                                const antiForgeryToken = commentForm.querySelector('input[name="__RequestVerificationToken"]').value;

                                // Build comment HTML
                                const newCommentHtml = `
                                    <div class="d-flex mb-4 comment-item" id="comment-${data.commentId}">
                                        <div class="flex-shrink-0">
                                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm"
                                                 style="width: 48px; height: 48px; font-size: 1.2rem;">
                                                ${data.avatarInitial}
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="bg-light p-3 rounded-4 shadow-sm position-relative">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <strong class="text-primary">${data.userEmail}</strong>
                                                    <small class="text-muted">${data.createdAt}</small>
                                                </div>
                                                <p class="mb-0 text-dark" style="white-space: pre-line;">${data.content}</p>
                                                <div class="position-absolute end-0 bottom-0 mb-2 me-3">
                                                    <form action="/Comments/Delete/${data.commentId}" method="post" class="d-inline delete-comment-form">
                                                        <input type="hidden" name="__RequestVerificationToken" value="${antiForgeryToken}" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0 py-0 px-2 rounded-pill"
                                                                onclick="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">
                                                            <i class="bi bi-trash"></i> Xóa
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                `;

                                // Insert at the top of the comment list
                                commentList.insertAdjacentHTML("afterbegin", newCommentHtml);
                                
                                // Reset form
                                commentForm.reset();

                                // Update count
                                if (commentCountEl) {
                                    const match = commentCountEl.textContent.match(/\d+/);
                                    if (match) {
                                        const count = parseInt(match[0]) + 1;
                                        commentCountEl.textContent = `Bình luận (${count})`;
                                    }
                                }
                            }
                        } else {
                            const errData = await response.json().catch(() => ({}));
                            alert(errData.message || "Không thể gửi bình luận.");
                        }
                    } catch (error) {
                        console.error("Error posting comment:", error);
                        alert("Đã xảy ra lỗi kết nối.");
                    }
                });
            }

            // AJAX Delete Comment (delegated handler)
            if (commentList) {
                commentList.addEventListener("submit", async function (e) {
                    if (e.target.classList.contains("delete-comment-form")) {
                        e.preventDefault();

                        const form = e.target;
                        const commentItem = form.closest(".comment-item");
                        const formData = new FormData(form);

                        try {
                            const response = await fetch(form.action, {
                                method: "POST",
                                body: formData,
                                headers: {
                                    "X-Requested-With": "XMLHttpRequest"
                                }
                            });

                            if (response.ok) {
                                const data = await response.json();
                                if (data.success) {
                                    // Remove comment item from DOM
                                    commentItem.remove();

                                    // Update count
                                    if (commentCountEl) {
                                        const match = commentCountEl.textContent.match(/\d+/);
                                        if (match) {
                                            const count = Math.max(0, parseInt(match[0]) - 1);
                                            commentCountEl.textContent = `Bình luận (${count})`;
                                            
                                            if (count === 0) {
                                                commentList.innerHTML = '<p class="text-muted fst-italic text-center py-4">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>';
                                            }
                                        }
                                    }
                                }
                            } else {
                                const errData = await response.json().catch(() => ({}));
                                alert(errData.message || "Bạn không có quyền xóa bình luận này.");
                            }
                        } catch (error) {
                            console.error("Error deleting comment:", error);
                            alert("Đã xảy ra lỗi khi xóa bình luận.");
                        }
                    }
                });
            }
        });
    </script>
}