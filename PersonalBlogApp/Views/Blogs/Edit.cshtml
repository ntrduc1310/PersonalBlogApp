@model PersonalBlogApp.ViewModels.BlogEditVM

@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block">
                &larr; Hủy và quay lại
            </a>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 px-md-5">
                    <h3 class="fw-bold text-dark mb-0">Chỉnh sửa bài viết</h3>
                    <p class="text-muted mt-1">Cập nhật nội dung hoặc thay đổi mức độ ưu tiên của bài viết.</p>
                </div>

                <div class="card-body p-4 p-md-5 pt-3">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <!-- Tiêu đề -->
                            <div class="col-md-8 mb-4">
                                <label asp-for="Title" class="form-label fw-medium text-dark">Tiêu đề bài viết <span class="text-danger">*</span></label>
                                <input asp-for="Title" class="form-control form-control-lg bg-light border-0" placeholder="Nhập tiêu đề..." />
                                <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Dropdown Priority -->
                            <div class="col-md-4 mb-4">
                                <label asp-for="Priority" class="form-label fw-medium text-dark">Độ ưu tiên</label>
                                <select asp-for="Priority" class="form-select form-select-lg bg-light border-0">
                                    <option value="5">5 - Rất cao</option>
                                    <option value="4">4 - Cao</option>
                                    <option value="3">3 - Trung bình</option>
                                    <option value="2">2 - Thấp</option>
                                    <option value="1">1 - Rất thấp</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <!-- Nội dung (TinyMCE) -->
                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-medium text-dark">Nội dung <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" id="tiny-editor" class="form-control bg-light border-0" rows="10" placeholder="Viết nội dung bài của bạn ở đây..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill fw-medium">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
        selector: '#tiny-editor',
        plugins: 'lists link image wordcount code table',
        toolbar: 'undo redo | bold italic underline | alignleft aligncenter alignright | numlist bullist | code',
        menubar: false,
        height: 350,
        setup: function (editor) {
        editor.on('change', function () {
        tinymce.triggerSave();
        });
        }
        });
    </script>
}