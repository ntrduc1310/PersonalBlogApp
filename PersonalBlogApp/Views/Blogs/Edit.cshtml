@model PersonalBlogApp.ViewModels.BlogEditVM

@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-2 mb-5" style="max-width: 850px;">
    <a asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block small hover-primary-text">
        &larr; Hủy và quay lại
    </a>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid var(--color-border) !important;">
        <div class="card-header bg-primary bg-gradient text-white p-4">
            <h4 class="mb-0 fw-bold">Chỉnh sửa bài viết</h4>
            <small class="opacity-75">Cập nhật nội dung hoặc thay đổi mức độ ưu tiên của bài viết.</small>
        </div>
        <div class="card-body p-4 p-md-5 bg-white">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- Validation summary -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <!-- Title field -->
                    <div class="col-md-9">
                        <label asp-for="Title" class="form-label fw-bold text-muted small">Tiêu đề bài viết <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control form-control-custom" placeholder="Nhập tiêu đề hấp dẫn..." required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Priority dropdown -->
                    <div class="col-md-3">
                        <label asp-for="Priority" class="form-label fw-bold text-muted small">Độ ưu tiên</label>
                        <select asp-for="Priority" class="form-select form-select-custom" required>
                            <option value="5">5 - Rất cao</option>
                            <option value="4">4 - Cao</option>
                            <option value="3">3 - Trung bình</option>
                            <option value="2">2 - Thấp</option>
                            <option value="1">1 - Rất thấp</option>
                        </select>
                    </div>

                    <!-- Content (TinyMCE) -->
                    <div class="col-12">
                        <label asp-for="Content" class="form-label fw-bold text-muted small">Nội dung bài viết <span class="text-danger">*</span></label>
                        <textarea asp-for="Content" id="tiny-editor" class="form-control form-control-custom" rows="12"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Submit and Cancel buttons -->
                <div class="d-flex justify-content-end gap-2 mt-5">
                    <a asp-action="Index" class="btn btn-premium-outline px-4 py-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-premium-primary px-5 py-2">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <!-- TinyMCE CDN integration -->
    <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#tiny-editor',
            plugins: 'lists link image wordcount code table',
            toolbar: 'undo redo | bold italic underline | alignleft aligncenter alignright | numlist bullist | code',
            menubar: false,
            height: 380,
            setup: function (editor) {
                editor.on('change', function () {
                    tinymce.triggerSave(); // Sync data from TinyMCE iframe to raw textarea for Validation
                });
            }
        });
    </script>
}