@model X.PagedList.IPagedList<PersonalBlogApp.Models.Blog>
@using X.PagedList.Mvc.Core
@inject Microsoft.AspNetCore.Identity.UserManager<PersonalBlogApp.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Danh Sách Bài Viết";
    var currentSort = ViewData["CurrentSort"] as string;
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentPriority = ViewData["CurrentPriority"] as int?;
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container mt-2">
    <!-- TempData Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Page Title & Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold m-0 page-title" style="font-size: 2.2rem;">
                Bài viết của bạn
            </h2>
            <p class="text-muted mb-0 small">Quản lý và xuất bản nội dung sáng tạo của bạn.</p>
        </div>
        
        <div class="d-flex align-items-center gap-2">
            <!-- Priority Sort -->
            @if (currentSort == "priority")
            {
                <a asp-action="Index" asp-route-search="@currentSearch" asp-route-priority="@currentPriority" class="btn btn-premium-outline px-4">
                    <i class="bi bi-clock-history me-1"></i> Mới nhất
                </a>
            }
            else
            {
                <a asp-action="Index" asp-route-sort="priority" asp-route-search="@currentSearch" asp-route-priority="@currentPriority" class="btn btn-premium-outline px-4">
                    <i class="bi bi-sort-numeric-down-alt me-1"></i> Độ ưu tiên
                </a>
            }
            
            <a asp-action="Create" class="btn btn-premium-primary px-4">
                <i class="bi bi-plus-circle-fill me-2"></i>Tạo bài viết
            </a>
        </div>
    </div>

    <!-- Search & Filter Form -->
    <form method="get" asp-action="Index" class="row g-2 mb-5 align-items-center">
        @if (!string.IsNullOrEmpty(currentSort))
        {
            <input type="hidden" name="sort" value="@currentSort" />
        }
        
        <div class="col-md-6 col-sm-12">
            <div class="input-group" style="height: 42px;">
                <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0 ps-0 rounded-end-3" placeholder="Tìm kiếm theo tiêu đề hoặc nội dung..." value="@currentSearch">
            </div>
        </div>
        
        <div class="col-md-4 col-sm-8">
            <select name="priority" class="form-select rounded-3" style="height: 42px;">
                <option value="">Tất cả độ ưu tiên</option>
                <option value="5" selected="@(currentPriority == 5 ? "selected" : null)">5 - Rất cao</option>
                <option value="4" selected="@(currentPriority == 4 ? "selected" : null)">4 - Cao</option>
                <option value="3" selected="@(currentPriority == 3 ? "selected" : null)">3 - Trung bình</option>
                <option value="2" selected="@(currentPriority == 2 ? "selected" : null)">2 - Thấp</option>
                <option value="1" selected="@(currentPriority == 1 ? "selected" : null)">1 - Rất thấp</option>
            </select>
        </div>
        
        <div class="col-md-2 col-sm-4 d-flex gap-2">
            <button type="submit" class="btn btn-premium-primary flex-grow-1" style="border-radius: 12px; height: 42px; padding: 0;">Lọc</button>
            <a asp-action="Index" class="btn btn-light text-danger border-0 d-flex align-items-center justify-content-center shadow-sm hover-up" title="Xóa bộ lọc" style="border-radius: 12px; width: 42px; height: 42px; padding: 0;">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="card border-0 bg-white rounded-4 shadow-sm p-5 text-center">
            <div class="text-muted mb-3">
                <i class="bi bi-journal-x" style="font-size: 3rem; color: #cbd5e1;"></i>
            </div>
            <h5 class="fw-bold text-dark">Chưa có bài viết nào</h5>
            <p class="text-muted small">Hãy bắt đầu viết bài viết đầu tiên của bạn để chia sẻ kiến thức ngay hôm nay!</p>
            <div class="mt-3">
                <a asp-action="Create" class="btn btn-premium-primary">Tạo bài viết đầu tiên</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card glass-card hover-up h-100 d-flex flex-column border-0" style="border-radius: var(--radius-lg);">
                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Priority badge & Created date -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    @switch (item.Priority)
                                    {
                                        case 5:
                                            <span class="badge badge-custom badge-inactive">5 - Rất cao</span>
                                            break;
                                        case 4:
                                            <span class="badge badge-custom badge-priority-high">4 - Cao</span>
                                            break;
                                        case 3:
                                            <span class="badge badge-custom badge-user">3 - Trung bình</span>
                                            break;
                                        case 2:
                                            <span class="badge badge-custom badge-active">2 - Thấp</span>
                                            break;
                                        default:
                                            <span class="badge badge-custom bg-light text-dark">1 - Rất thấp</span>
                                            break;
                                    }
                                </div>
                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</small>
                            </div>

                            <!-- Blog Title -->
                            <h4 class="card-title fw-bold mb-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark hover-primary-text" style="transition: var(--transition-smooth);">
                                    @item.Title
                                </a>
                            </h4>

                            <!-- Blog Excerpt (Strip HTML tags) -->
                            <p class="card-text text-muted small mb-4 flex-grow-1">
                                @{
                                    var plainText = System.Text.RegularExpressions.Regex.Replace(item.Content ?? "", "<.*?>", string.Empty);
                                    if (plainText.Length > 120) plainText = plainText.Substring(0, 117) + "...";
                                }
                                @plainText
                            </p>

                            <hr class="opacity-25 mb-3">

                            <!-- Author Info (For Admin View) -->
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                         style="width: 32px; height: 32px; font-size: 0.85rem;">
                                        @(item.User?.Email?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <span class="small fw-semibold text-muted" style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.User?.Email">
                                        @(item.User?.Email ?? "Ẩn danh")
                                    </span>
                                </div>

                                <!-- Action Buttons -->
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-premium-outline px-3" style="padding: 0.35rem 0.75rem;">
                                        Xem
                                    </a>
                                    @if (User.IsInRole("Admin") || item.UserId == currentUserId)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning border-0 px-2 rounded-circle" title="Sửa">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0 px-2 rounded-circle" title="Xóa">
                                            <i class="bi bi-trash3-fill"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination Navigation Controls -->
        <div class="d-flex justify-content-center mt-5">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, sort = currentSort, search = currentSearch, priority = currentPriority }),
                new X.PagedList.Web.Common.PagedListRenderOptions {
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new string[] { "page-link" },
                    UlElementClasses = new string[] { "pagination", "justify-content-center" }
                })
        </div>
    }
</div>

<style>
    .hover-primary-text:hover {
        color: var(--color-primary-end) !important;
    }
</style>