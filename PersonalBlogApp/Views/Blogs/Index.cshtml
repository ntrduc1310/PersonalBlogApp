@model IEnumerable<PersonalBlogApp.Models.Blog>

@{
    ViewData["Title"] = "Danh Sách Bài Viết";
}

@if (!Model.Any())
{
    <div class="alert alert-info">Bạn chưa có bài viết nào ở đây cả. Hãy tạo bài đầu tiên!</div>
}
else
{
    <div class="table-responsive shadow-sm rounded bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 45%;">Tiêu đề</th>
                    <th style="width: 20%;">Mức ưu tiên</th>
                    <th style="width: 20%;">Ngày tạo</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th style="width: 15%;">Tác giả (Admin View)</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                @item.Title
                            </a>
                        </td>
                        <td>
                            @switch (item.Priority)
                            {
                                case 5:
                                    <span class="badge bg-danger">5 - Rất cao</span>
                                    ; break;
                                case 4:
                                    <span class="badge bg-warning text-dark">4 - Cao</span>
                                    ; break;
                                case 3:
                                    <span class="badge bg-info text-dark">3 - Trung bình</span>
                                    ; break;
                                case 2:
                                    <span class="badge bg-secondary">2 - Thấp</span>
                                    ; break;
                                default:
                                    <span class="badge bg-light text-dark">1 - Rất thấp</span>
                                    ; break;
                            }
                        </td>
                        <td class="text-muted">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td class="text-muted">@item.User?.Email</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
