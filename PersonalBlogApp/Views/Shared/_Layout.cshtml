<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PersonalBlog</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PersonalBlogApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light navbar-custom mb-5 py-3">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-rocket-takeoff-fill fs-4 text-primary"></i>
                    <span>PersonalBlog</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blogs" ? "active" : "")" asp-area="" asp-controller="Blogs" asp-action="Index">Bài viết</a>
                            </li>
                        }
                        @if (User?.IsInRole("Admin") ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom text-danger @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")" asp-area="" asp-controller="Users" asp-action="Index">Quản lý User</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <!-- Dynamic Breadcrumb Navigation -->
        @{
            var controller = ViewContext.RouteData.Values["controller"]?.ToString();
            var action = ViewContext.RouteData.Values["action"]?.ToString();
        }
        @if (controller != "Home" || action != "Index")
        {
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb bg-white rounded-pill px-4 py-2.5 shadow-sm border border-light">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-house-door-fill me-1"></i>Trang chủ</a></li>
                    
                    @if (controller == "Blogs")
                    {
                        @if (action == "Index")
                        {
                            <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Bài viết</li>
                        }
                        else
                        {
                            <li class="breadcrumb-item"><a asp-controller="Blogs" asp-action="Index" class="text-decoration-none text-muted">Bài viết</a></li>
                            @if (action == "Create")
                            {
                                <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Tạo bài viết</li>
                            }
                            else if (action == "Edit")
                            {
                                <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Chỉnh sửa</li>
                            }
                            else if (action == "Details")
                            {
                                <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Chi tiết bài viết</li>
                            }
                        }
                    }
                    else if (controller == "Users")
                    {
                        @if (action == "Index")
                        {
                            <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Quản lý User</li>
                        }
                        else
                        {
                            <li class="breadcrumb-item"><a asp-controller="Users" asp-action="Index" class="text-decoration-none text-muted">Quản lý User</a></li>
                            @if (action == "Edit")
                            {
                                <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Chỉnh sửa</li>
                            }
                            else if (action == "Delete")
                            {
                                <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Xóa</li>
                            }
                        }
                    }
                    else if (controller == "Profile")
                    {
                        <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">Hồ sơ cá nhân</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item active text-primary fw-semibold" aria-current="page">@controller</li>
                    }
                </ol>
            </nav>
        }

        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom mt-auto py-4">
        <div class="container text-center">
            <span class="small">&copy; 2026 - PersonalBlog - Developed with <i class="bi bi-heart-fill text-danger mx-1"></i> under Professional Standards.</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
