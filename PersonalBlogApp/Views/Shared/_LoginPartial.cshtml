@using Microsoft.AspNetCore.Identity
@using PersonalBlogApp.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var avatarLetter = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U";

    <li class="nav-item">
        <a id="manage" class="nav-link nav-link-custom d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Index" title="Quản lý tài khoản">
            <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" 
                 style="width: 32px; height: 32px; font-size: 0.9rem;">
                @avatarLetter
            </div>
            <span class="d-none d-lg-inline">Xin chào, @(User.Identity?.Name)</span>
        </a>
    </li>
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="btn btn-sm btn-premium-outline px-3 py-1-5 border-0">
                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link nav-link-custom" id="register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-premium-primary px-4 py-2 text-decoration-none" id="login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    </li>
}
</ul>
