@model PersonalBlogApp.Models.ApplicationUser
@{
    ViewData["Title"] = "Xóa Người dùng";
}

<div class="container mt-2">
    <!-- Back link -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-premium rounded-4 p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="warning-circle bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                    </div>
                    <h2 class="fw-bold text-danger m-0">Xác nhận xóa tài khoản</h2>
                    <p class="text-muted small mt-2">Hành động này không thể hoàn tác. Vui lòng xác nhận kỹ thông tin người dùng bên dưới.</p>
                </div>

                <div class="bg-light rounded-4 p-3.5 mb-4">
                    <div class="mb-3">
                        <span class="text-muted small d-block">Địa chỉ Email</span>
                        <span class="fw-semibold text-dark">@Model.Email</span>
                    </div>
                    <div class="mb-3">
                        <span class="text-muted small d-block">User ID</span>
                        <span class="font-monospace text-muted small">@Model.Id</span>
                    </div>
                    <div>
                        <span class="text-muted small d-block">Tên tài khoản</span>
                        <span class="fw-semibold text-dark">@Model.UserName</span>
                    </div>
                </div>

                <div class="alert alert-warning rounded-4 shadow-sm mb-4 small" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Xóa tài khoản này sẽ tự động xóa tất cả các bài viết và bình luận liên quan đến họ.
                </div>

                <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
                    <div class="row g-3">
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-premium-outline rounded-pill w-100 py-2.5">
                                Hủy bỏ
                            </a>
                        </div>
                        <div class="col-6">
                            <button type="submit" class="btn btn-danger rounded-pill w-100 py-2.5">
                                <i class="bi bi-trash-fill me-2"></i>Xác nhận xóa
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
