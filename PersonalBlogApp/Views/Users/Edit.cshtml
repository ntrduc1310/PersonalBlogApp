@model PersonalBlogApp.ViewModels.UserEditVM
@{
    ViewData["Title"] = "Chỉnh sửa Người dùng";
}

<div class="container mt-2">
    <!-- Back link -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-premium rounded-4 p-4 p-md-5">
                <div class="mb-4">
                    <h2 class="fw-bold page-title m-0">Chỉnh sửa Thành viên</h2>
                    <p class="text-muted small">Cập nhật vai trò hệ thống hoặc thay đổi trạng thái kích hoạt tài khoản.</p>
                </div>

                <form method="post" asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <!-- User Email (ReadOnly) -->
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-semibold">Địa chỉ Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-4">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control bg-light border-start-0 rounded-end-4" readonly />
                        </div>
                    </div>

                    <!-- User Role -->
                    <div class="mb-4">
                        <label asp-for="Role" class="form-label text-muted small fw-semibold">Vai trò hệ thống</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-4">
                                <i class="bi bi-shield-check"></i>
                            </span>
                            <select asp-for="Role" class="form-select border-start-0 rounded-end-4">
                                <option value="User">User (Thành viên thường)</option>
                                <option value="Admin">Admin (Quản trị viên)</option>
                            </select>
                        </div>
                        <span asp-validation-for="Role" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Active Status Toggle -->
                    <div class="mb-4">
                        <div class="form-check form-switch card-switch-custom p-3 rounded-4 bg-light d-flex align-items-center justify-content-between">
                            <div class="ms-0">
                                <label class="form-check-label fw-semibold text-dark d-block" for="isActiveSwitch">Trạng thái kích hoạt</label>
                                <span class="text-muted small">Cho phép tài khoản này đăng nhập vào hệ thống.</span>
                            </div>
                            <input class="form-check-input ms-3 me-0 fs-4" type="checkbox" role="switch" id="isActiveSwitch" asp-for="IsActive">
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-premium-primary rounded-pill py-2.5">
                            <i class="bi bi-save-fill me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
