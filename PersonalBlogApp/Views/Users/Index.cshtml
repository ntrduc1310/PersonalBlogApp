@model IEnumerable<PersonalBlogApp.ViewModels.UserItemVM>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-2 mb-5">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold m-0" style="color: #2c3e50; font-size: 2.2rem;">
                Quản lý người dùng
            </h2>
            <p class="text-muted mb-0 small">Danh sách các tài khoản đăng ký trên hệ thống và cài đặt phân quyền.</p>
        </div>
    </div>

    <!-- Alert notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search & Filter card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4" style="border: 1px solid var(--color-border) !important;">
        <div class="card-body p-4">
            <form method="get" asp-action="Index" class="row g-3 align-items-center">
                <div class="col-md-9 col-sm-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3" style="border: 1.5px solid var(--color-border); border-right: none;">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="search" value="@ViewData["CurrentFilter"]" 
                               class="form-control form-control-custom rounded-start-0 rounded-end-pill ps-2" 
                               placeholder="Tìm kiếm tài khoản theo email hoặc tên đăng nhập..." />
                    </div>
                </div>
                <div class="col-md-3 col-sm-4 d-grid">
                    <button type="submit" class="btn btn-premium-primary py-2-5">
                        Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Users table -->
    <div class="table-responsive mt-4">
        <table class="table table-custom align-middle">
            <thead class="text-uppercase small text-muted">
                <tr>
                    <th class="ps-4">Tài khoản</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th class="pe-4 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted fst-italic">
                            Không tìm thấy tài khoản người dùng nào.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm"
                                         style="width: 40px; height: 40px; font-size: 1rem; background: linear-gradient(135deg, #94a3b8, #64748b) !important;">
                                        @user.Email.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-semibold text-dark">@user.Email</h6>
                                        <small class="text-muted" style="font-size: 0.75rem;">ID: @user.Id</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge-custom badge-admin"><i class="bi bi-shield-fill-check"></i> Admin</span>
                                }
                                else
                                {
                                    <span class="badge-custom badge-user"><i class="bi bi-person-fill"></i> User</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge-custom badge-active"><i class="bi bi-check-circle-fill"></i> Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-custom badge-inactive"><i class="bi bi-slash-circle-fill"></i> Vô hiệu hóa</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.Id" 
                                       class="btn btn-sm btn-premium-outline px-3" style="padding: 0.35rem 0.85rem; font-size: 0.85rem;">
                                        <i class="bi bi-pencil-square me-1"></i> Thiết lập
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" 
                                       class="btn btn-sm btn-premium-outline-danger px-3" style="padding: 0.35rem 0.85rem; font-size: 0.85rem;">
                                        <i class="bi bi-trash-fill me-1"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
